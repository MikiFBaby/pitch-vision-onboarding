# ─────────────────────────────────────────────────────────────
# Pitch Vision Web — Production Environment Variables
#
# Copy to .env.production and fill in all values:
#   cp .env.production.template .env.production
#
# NEXT_PUBLIC_* vars are baked into the client bundle at build time.
# All other vars are server-side only (available in API routes).
# ─────────────────────────────────────────────────────────────

# ═══ App ═══
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://app.pitchvision.io

# ═══ Supabase ═══
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ═══ Firebase Auth ═══
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ═══ Cron / Internal Auth ═══
CRON_SECRET=

# ═══ SMTP (Google Workspace) ═══
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=reports@pitchperfectsolutions.net
SMTP_PASS=
SMTP_FROM="PitchVision Alerts" <reports@pitchperfectsolutions.net>

# ═══ Slack ═══
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_HIRES_CHANNEL_ID=
SLACK_DIALEDIN_CHANNEL=
SLACK_MANAGERS_CHANNEL=
SLACK_ONBOARDING_CHANNEL_ID=
SLACK_ONBOARDING_BOT_TOKEN=

# Slack Attendance (SAM)
SLACK_ATTENDANCE_BOT_TOKEN=
SLACK_ATTENDANCE_SIGNING_SECRET=
SLACK_ATTENDANCE_CHANNEL_ID=
SLACK_ATTENDANCE_AUTHORIZED_USERS=

# ═══ DocuSeal ═══
DOCUSEAL_API_URL=https://api.docuseal.com
DOCUSEAL_API_KEY=

# ═══ DialedIn ═══
DIALEDIN_INGEST_API_KEY=
DIALEDIN_PORTAL_USER=
DIALEDIN_PORTAL_PASS=
DIALEDIN_SLACK_CHANNEL_ID=
DIALEDIN_WEBHOOK_SECRET=
DIALEDIN_S3_BUCKET=

# ═══ Retreaver ═══
REATREVER_API_KEY=
RETREAVER_IMAP_USER=
RETREAVER_IMAP_PASS=
RETREAVER_EMAIL_SENDERS=

# ═══ AWS (S3 for Retreaver + DialedIn) ═══
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ═══ AI / LLM ═══
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# ═══ Resend (onboarding emails) ═══
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pitch Vision <onboarding@resend.dev>

# ═══ Revenue Rate Overrides (optional) ═══
# REVENUE_RATE_ACA=10.50
# REVENUE_RATE_MEDICARE=7.00
# BREAK_EVEN_TPH_ACA=2.5
# BREAK_EVEN_TPH_MEDICARE=3.5

# ═══ Attendance Webhooks ═══
ATTENDANCE_WEBHOOK_SECRET=
GOOGLE_SHEETS_WEBHOOK_URL=
# ATTENDANCE_DRY_RUN=false

# ═══ Microsoft Teams (optional) ═══
# TEAMS_ATTENDANCE_WEBHOOK_URL=

# ═══ Feature Flags ═══
# NEXT_PUBLIC_QA_ONLY=false
